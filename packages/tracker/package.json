{
  "name": "@biocrypt/tracker",
  "version": "0.4.3",
  "description": "Zero-dep WebSocket tracker for BioCrypt v1.1 — relays mints (incl. 50-coin batch-mint), spends and encrypted envelopes; also ships `biocrypt-mine` and `biocrypt-transfer` CLIs.",
  "license": "MIT",
  "author": "BioCrypt Contributors",
  "homepage": "https://www.biocrypt.net/download",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pipikaex/biocrypt.git",
    "directory": "packages/tracker"
  },
  "bugs": {
    "url": "https://github.com/pipikaex/biocrypt/issues"
  },
  "keywords": [
    "biocrypt",
    "zbio",
    "tracker",
    "websocket",
    "decentralized",
    "dna256",
    "miner"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "biocrypt-tracker": "bin/biocrypt-tracker.mjs",
    "biocrypt-mine": "bin/biocrypt-mine.mjs",
    "biocrypt-transfer": "bin/biocrypt-transfer.mjs"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "start": "node bin/biocrypt-tracker.mjs",
    "dev": "tsc --watch",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "@biocrypt/core": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=22"
  }
}
